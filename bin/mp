def record_taskspec_event(event):
    events_path = os.path.join(ROOT, "run", "taskspec-events.jsonl")
    os.makedirs(os.path.dirname(events_path), exist_ok=True)
    descriptor = os.open(events_path, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)
    with os.fdopen(descriptor, "a", encoding="utf-8") as stream:
        stream.write(json.dumps(event, ensure_ascii=False, separators=(",", ":")) + "\n")
        stream.flush()
        os.fsync(stream.fileno())
    os.chmod(events_path, 0o600)


def compile_owner_task_spec(task_id, *, bypass_memory=False):
    started = time.monotonic()
    slug = ""
    profile_revision = None
    requested_claim_count = 0
    stage = "board"
    todo_base = (
        os.environ.get("MYPEOPLE_TODO_URL")
        or os.environ.get("TODO_URL")
        or f"http://127.0.0.1:{ENV.get('TODO_PORT', '9933')}"
    )
    try:
        board = http_json(
            "/todo/board", base=todo_base, token=ENV.get("QUEUE_SECRET", "")
        )
        stage = "compile"
        task = (board.get("tasks") or {}).get(task_id)
        if not isinstance(task, dict):
            raise TaskSpecError("unknown_task")
        slug = str(task.get("projectSlug") or "").strip()
        if not slug:
            raise TaskSpecError("project_slug_required")
        profiles_dir = os.path.realpath(
            ENV.get("PROJECT_PROFILES_DIR", os.path.join(ROOT, "run", "project-profiles"))
        )
        profile = load_profile(profiles_dir, slug)
        profile_revision = profile.get("revision")
        canary_requested = task.get("memoryCanary") is True
        comparison = task.get("experiment", {}).get("memory_comparison", {})
        comparison_baseline = (
            ENV.get("MYPEOPLE_MEMORY_COMPARISON_ENABLED") == "1"
            and isinstance(comparison, dict)
            and comparison.get("arm") == "baseline"
        )
        if bypass_memory and not canary_requested and not comparison_baseline:
            raise TaskSpecError("canary_not_requested")
        if (
            str(task.get("contextQuestion") or "").strip()
            and profile.get("memory", {}).get("enabled") is True
        ):
            requested_claim_count = profile.get("limits", {}).get("memoryTopK", 0)
        if canary_requested:
            runtime_dir = os.path.realpath(os.path.join(ROOT, "run"))
            control = load_memory_canary_control(runtime_dir)
            try:
                attempt = compile_memory_canary_attempt(
                    task=task,
                    profile=profile,
                    control=control,
                    compile_spec=compile_task_spec,
                    recall=lambda request: call_memory_gateway(
                        profile,
                        request["question"],
                        max_chars=request["maxChars"],
                    ),
                    bypass=bypass_memory,
                )
                spec = attempt["candidate"]
                append_memory_canary_receipt(runtime_dir, attempt["receipt"])
            except MemoryCanaryError as error:
                raise TaskSpecError(error.code) from error
        else:
            spec = compile_task_spec(task, profile)
        taskspecs_dir = os.path.realpath(
            ENV.get("TASKSPECS_DIR", os.path.join(ROOT, "run", "taskspecs"))
        )
        stage = "write"
        taskspec_path = write_task_spec(taskspecs_dir, task_id, spec)
    except (ProfileError, TaskSpecError, MemoryCanaryError) as error:
        code = error.code
        record_taskspec_event({
            "taskId": task_id,
            "projectSlug": slug,
            "profileRevision": profile_revision,
            "memoryStatus": "error",
            "error": code,
            "requestedClaimCount": requested_claim_count,
            "returnedClaimCount": 0,
            "embeddedClaimCount": 0,
            "claimCount": 0,
            "elapsedMilliseconds": round((time.monotonic() - started) * 1000),
            "responseCharacters": 0,
            "aiUsage": "not_measured",
        })
        if isinstance(error, (ProfileError, MemoryCanaryError)):
            raise TaskSpecError(code) from error
        raise
    except (RuntimeError, OSError, json.JSONDecodeError) as error:
        code = (
            "board_unavailable" if stage == "board"
            else "taskspec_write_failed" if stage == "write"
            else "taskspec_compile_failed"
        )
        record_taskspec_event({
            "taskId": task_id,
            "projectSlug": slug,
            "profileRevision": profile_revision,
            "memoryStatus": "error",
            "error": code,
            "requestedClaimCount": requested_claim_count,
            "returnedClaimCount": 0,
            "embeddedClaimCount": 0,
            "claimCount": 0,
            "elapsedMilliseconds": round((time.monotonic() - started) * 1000),
            "responseCharacters": 0,
            "aiUsage": "not_measured",
        })
        raise TaskSpecError(code) from error
    metadata = getattr(spec, "memory_metadata", {})
    returned_claim_count = metadata.get(
        "returnedClaimCount", len(spec["memoryClaims"])
    )
    embedded_claim_count = metadata.get(
        "embeddedClaimCount", len(spec["memoryClaims"])
    )
    record_taskspec_event({
        "taskId": task_id,
        "projectSlug": spec["projectSlug"],
        "profileRevision": spec["profileRevision"],
        "memoryStatus": spec["memoryStatus"],
        "error": None,
        "requestedClaimCount": metadata.get(
            "requestedClaimCount", requested_claim_count
        ),
        "returnedClaimCount": returned_claim_count,
        "embeddedClaimCount": embedded_claim_count,
        "claimCount": embedded_claim_count,
        "elapsedMilliseconds": round((time.monotonic() - started) * 1000),
        "responseCharacters": metadata.get("responseCharacters", 0),
        "aiUsage": metadata.get("aiUsage", "not_measured"),
    })
    return taskspec_path

CODEX_BOSS_POLICY = """
## Codex backend policy

Claude is currently disabled. Run delegated agents through Codex explicitly:

`mp spawn <agent_id> --backend codex --model gpt-5.6-luna --boss <your_id> --owner-task <card_id>`

Use `gpt-5.6-luna` for routine delegated work. Escalate deliberately to
`gpt-5.6-terra` or `gpt-5.6-sol` when the task requires it.
Do not spawn a Claude worker while Claude remains disabled.
"""

WORKER_CONTRACT_VERSION = "1.0.0"
WORKER_POLICY = """
# MyPeople owner worker contract

Work only on the task in `OWNER_TASK_ID`. Read the TaskSpec at
`MYPEOPLE_TASKSPEC_PATH` before changing files. Follow the repository's own
instructions independently; MyPeople does not modify them.

Respect the TaskSpec acceptance criteria, verification commands, allowed
actions, forbidden actions, and context limits. When implementation and checks
finish, report them with:

`mp complete "<concise summary>" --proof "<verification command and result>"`

Attach visual or executable results with repeatable `--proof-file <path>` and
`--proof-url <url>`. This command moves the task to `review` and notifies
the Boss. Do not close the task yourself; Boss/CEO owns verification and
closure.
"""

def resolve_owner_task_context(taskspec_path, requested_cwd):
    try:
        raw = pathlib.Path(taskspec_path).read_bytes()
        document = json.loads(raw.decode("utf-8"))
    except (OSError, UnicodeError, json.JSONDecodeError) as error:
        raise TaskSpecError("taskspec_runtime_invalid") from error
    if not isinstance(document, dict):
        raise TaskSpecError("taskspec_runtime_invalid")
    working_directory = str(document.get("workingDirectory") or "").strip()
    if not working_directory or not os.path.isabs(working_directory):
        raise TaskSpecError("working_directory_invalid")
    cwd = os.path.realpath(working_directory)
    if not os.path.isdir(cwd):
        raise TaskSpecError("working_directory_missing")
    if not os.access(cwd, os.R_OK | os.X_OK):
        raise TaskSpecError("working_directory_unreadable")
    if requested_cwd and os.path.realpath(requested_cwd) != cwd:
        raise TaskSpecError("working_directory_mismatch")
    return {
        "cwd": cwd,
        "document": document,
        "taskspec_sha256": hashlib.sha256(raw).hexdigest(),
    }

def _open_absolute_directory_without_symlinks(path):
    absolute = pathlib.Path(path)
    if not absolute.is_absolute():
        raise OSError("role storage must be absolute")
    flags = (
        os.O_RDONLY
        | getattr(os, "O_DIRECTORY", 0)
        | getattr(os, "O_NOFOLLOW", 0)
        | getattr(os, "O_CLOEXEC", 0)
    )
    descriptor = os.open(os.path.sep, flags)
    try:
        for component in absolute.parts[1:]:
            child = os.open(component, flags, dir_fd=descriptor)
            os.close(descriptor)
            descriptor = child
        return descriptor
    except Exception:
        os.close(descriptor)
        raise

def _open_private_child(parent_descriptor, name):
    try:
        os.mkdir(name, 0o700, dir_fd=parent_descriptor)
    except FileExistsError:
        pass
    flags = (
        os.O_RDONLY
        | getattr(os, "O_DIRECTORY", 0)
        | getattr(os, "O_NOFOLLOW", 0)
        | getattr(os, "O_CLOEXEC", 0)
    )
    child = os.open(name, flags, dir_fd=parent_descriptor)
    os.fchmod(child, 0o700)
    return child

def _read_private_regular_file(parent_descriptor, name):
    flags = (
        os.O_RDONLY
        | getattr(os, "O_NOFOLLOW", 0)
        | getattr(os, "O_CLOEXEC", 0)
    )
    try:
        descriptor = os.open(name, flags, dir_fd=parent_descriptor)
    except FileNotFoundError:
        return None
    try:
        if not stat.S_ISREG(os.fstat(descriptor).st_mode):
            raise OSError("role contract is not a regular file")
        with os.fdopen(descriptor, "r", encoding="utf-8") as handle:
            descriptor = -1
            return handle.read()
    finally:
        if descriptor >= 0:
            os.close(descriptor)

def _write_private_regular_file(parent_descriptor, name, content):
    temporary = f".{name}.{os.getpid()}.{time.time_ns()}.tmp"
    flags = (
        os.O_WRONLY
        | os.O_CREAT
        | os.O_EXCL
        | getattr(os, "O_NOFOLLOW", 0)
        | getattr(os, "O_CLOEXEC", 0)
    )
    descriptor = os.open(temporary, flags, 0o600, dir_fd=parent_descriptor)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            descriptor = -1
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(
            temporary,
            name,
            src_dir_fd=parent_descriptor,
            dst_dir_fd=parent_descriptor,
        )
    finally:
        if descriptor >= 0:
            os.close(descriptor)
        try:
            os.unlink(temporary, dir_fd=parent_descriptor)
        except FileNotFoundError:
            pass

def materialize_worker_contract():
    content = WORKER_POLICY.strip() + "\n"
    digest = hashlib.sha256(content.encode("utf-8")).hexdigest()
    isolated_override = (
        os.environ.get("MP_VERIFY_ISOLATED") == "1"
        and os.environ.get("MYPEOPLE_ROLE_BUNDLES_DIR")
    )
    if isolated_override:
        base = pathlib.Path(isolated_override)
        components = ("worker", digest)
        make_base_private = True
    else:
        base = pathlib.Path(ROOT) / "run"
        components = ("roles", "worker", digest)
        make_base_private = False
    base = pathlib.Path(os.path.abspath(base))
    target_dir = base.joinpath(*components)
    if os.path.commonpath((str(base), str(target_dir))) != str(base):
        raise OSError("role contract path escaped runtime storage")

    descriptor = _open_absolute_directory_without_symlinks(base)
    try:
        if make_base_private:
            os.fchmod(descriptor, 0o700)
        for component in components:
            child = _open_private_child(descriptor, component)
            os.close(descriptor)
            descriptor = child
        current = _read_private_regular_file(descriptor, "CONTRACT.md")
        if current != content:
            _write_private_regular_file(descriptor, "CONTRACT.md", content)
        contract_descriptor = os.open(
            "CONTRACT.md",
            os.O_RDONLY
            | getattr(os, "O_NOFOLLOW", 0)
            | getattr(os, "O_CLOEXEC", 0),
            dir_fd=descriptor,
        )
        try:
            if not stat.S_ISREG(os.fstat(contract_descriptor).st_mode):
                raise OSError("role contract is not a regular file")
            os.fchmod(contract_descriptor, 0o600)
        finally:
            os.close(contract_descriptor)
    finally:
        os.close(descriptor)
    return {
        "path": str(target_dir / "CONTRACT.md"),
        "sha256": digest,
        "version": WORKER_CONTRACT_VERSION,
        "content": content,
    }

def mount_worker_contract(args, backend, contract):
    mounted = list(args)
    if backend == "codex":
        mounted += [
            "--config",
            "developer_instructions=" + json.dumps(
                contract["content"].rstrip(), ensure_ascii=False
            ),
        ]
    elif backend == "claude":
        mounted += ["--append-system-prompt-file", contract["path"]]
    else:
        raise ValueError(f"unsupported backend: {backend}")
    return mounted

def ensure_codex_doctrine(cwd, source=None):
    source_path = pathlib.Path(source or os.path.join(ROOT, "boss-CLAUDE.md"))
    target_dir = pathlib.Path(os.path.realpath(cwd))
    target_dir.mkdir(parents=True, exist_ok=True)
    target = target_dir / "AGENTS.md"
    rendered = source_path.read_text(encoding="utf-8").rstrip() + "\n\n" + CODEX_BOSS_POLICY.strip() + "\n"
    try:
        if target.read_text(encoding="utf-8") == rendered:
            return str(target)
    except FileNotFoundError:
        pass
    temporary = target.with_name(f"{target.name}.{os.getpid()}.{time.time_ns()}.tmp")
    with temporary.open("w", encoding="utf-8") as handle:
        handle.write(rendered)
        handle.flush()
        os.fsync(handle.fileno())
    os.chmod(temporary, 0o600)
    os.replace(temporary, target)
    return str(target)

def is_managed_codex_cwd(cwd):
    real_cwd = os.path.realpath(cwd)
    managed_roots = (
        os.path.realpath(os.path.join(ROOT, "run", "boss")),
        os.path.realpath(os.path.join(ROOT, "run", "eng")),
        os.path.realpath(os.path.join(ROOT, "run", "nightwatch")),
    )
    return any(real_cwd == root or real_cwd.startswith(root + os.sep) for root in managed_roots)

def resolve_provider_runtime(
    aid,
    backend,
    is_master,
    tab,
    requested_model,
    model_explicit,
):
    model = requested_model
    profile_id = ""
    provider_home = ""
    if backend != "codex":
        return model, profile_id, provider_home
    bindings = load_provider_json(
        os.environ.get(
            "PROVIDER_BINDINGS_PATH",
            os.path.join(ROOT, "run", "provider-bindings.json"),
        ),
        {},
    )
    profiles = load_provider_json(
        os.environ.get(
            "PROVIDER_PROFILES_PATH",
            os.path.join(ROOT, "run", "provider-profiles.json"),
        ),
        {},
    )
    if bindings.get("globalProfile"):
        profile_id = resolve_profile(bindings, aid)
        profile = profiles.get(profile_id, {}) if isinstance(profiles, dict) else {}
        if not model_explicit:
            role = "boss" if is_master else "nightwatch" if tab == "Nightwatch" else "engineer"
            model = resolve_model(profile, role)
        provider_home = codex_home(
            os.environ.get(
                "PROVIDER_HOMES_DIR",
                os.path.join(ROOT, "run", "provider-homes"),
            ),
            profile_id,
        )
        os.makedirs(provider_home, mode=0o700, exist_ok=True)
        os.chmod(provider_home, 0o700)
    return model, profile_id, provider_home

def _build_launch_args(agent_id, cwd, boss, is_master, model, backend):
    aid = full_agent_id(agent_id)
    host, session, tab = parse_agent_id(aid)
    boss_full = full_agent_id(boss) if boss else ""
    cwd = os.path.realpath(cwd or (os.path.join(ROOT, "run", "boss") if is_master else os.path.join(ROOT, "run", "eng", tab)))
    os.makedirs(cwd, exist_ok=True)
    if backend == "codex":
        real_cwd = os.path.realpath(cwd)
        args = ["codex", "--sandbox", "danger-full-access", "--ask-for-approval", "never", "-C", real_cwd]
        if model:
            args += ["--model", model]
        if is_managed_codex_cwd(real_cwd):
            args += ["--config", f'projects.{json.dumps(real_cwd)}.trust_level = "trusted"']
    elif backend == "claude":
        trust_claude(cwd)
        settings = os.path.expanduser("~/.claude/settings.json")
        sd = load_json(settings, {})
        sd["skipDangerousModePermissionPrompt"] = True
        atomic_json(settings, sd)
        args = ["claude", "--dangerously-skip-permissions", "--plugin-dir", os.path.join(ROOT, "plugins", "tmux-boss-hooks")]
        if model:
            args += ["--model", model]
        if is_master:
            args += ["--append-system-prompt-file", os.path.join(ROOT, "boss-CLAUDE.md")]
        elif tab == "Nightwatch" and os.path.exists(os.path.join(cwd, "CLAUDE.md")):
            args += ["--append-system-prompt-file", os.path.join(cwd, "CLAUDE.md")]
    else:
        raise ValueError(f"unsupported backend: {backend}")
    return aid, host, session, tab, cwd, boss_full, args

def build_launch(agent_id, cwd, boss, is_master, model, backend):
    aid, host, session, tab, cwd, boss_full, args = _build_launch_args(agent_id, cwd, boss, is_master, model, backend)
    return shlex.join(args)

def queue_register(rec):
    try: http_json("/agents/register", "POST", rec)
    except Exception as e: print(f"warning: register deferred: {e}", file=sys.stderr)

def recorder(session, tab):
    name = "rec-" + tab
    if run_tmux(["has-session", "-t", name], check=False).returncode == 0: return
    os.makedirs(os.path.expanduser("~/recordings"), exist_ok=True)
    cast = os.path.expanduser(f"~/recordings/{ENV.get('HOST_ID')}-{tab}.cast")
    command = f"asciinema rec --quiet --append -c {shlex.quote(f'TMUX= tmux attach -rt mc-{session}:{tab}')} {shlex.quote(cast)}"
    run_tmux(["new-session", "-d", "-s", name, command], check=False)

def wait_for_composer(target, timeout=30):
    """Wait for the selected backend's interactive composer before the first turn."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        pane = run_tmux(["capture-pane", "-p", "-S", "-80", "-t", target], capture=True, check=False)
        text = pane.stdout or ""
        if pane.returncode == 0 and "Do you trust the contents of this directory?" in text:
            run_tmux(["send-keys", "-t", target, "1", "Enter"], check=False)
            time.sleep(.5)
            continue
        if pane.returncode == 0 and any(marker in text for marker in (
            "bypass permissions on", "Claude Code", "OpenAI Codex", "How can I help", "Try"
        )):
            return True
        time.sleep(.5)
    return False

def wait_for_stable_window(target, duration=None, poll=0.1):
    stable_for = (
        float(os.environ.get("MYPEOPLE_RESUME_STABILITY_SEC", "1"))
        if duration is None
        else float(duration)
    )
    deadline = time.monotonic() + max(0.0, stable_for)
    while True:
        if not window_exists(target):
            return False
        if time.monotonic() >= deadline:
            return True
        time.sleep(max(0.01, float(poll)))

def resolve_owner_runtime(ns, receipt_record=None):
    if not ns.owner_task:
        return "", {}, None
    if receipt_record is None:
        if getattr(ns, "without_memory", False):
            taskspec_path = compile_owner_task_spec(
                ns.owner_task,
                bypass_memory=True,
            )
        else:
            taskspec_path = compile_owner_task_spec(ns.owner_task)
        taskspec_context = resolve_owner_task_context(taskspec_path, ns.cwd)
        receipt = latest_memory_canary_receipt(
            os.path.realpath(os.path.join(ROOT, "run")),
            ns.owner_task,
        )
        if isinstance(receipt, dict) and receipt.get("eventType") == "start":
            taskspec_context["memory_canary_attempt_id"] = receipt.get("attemptId")
        return taskspec_path, taskspec_context, materialize_worker_contract()
    if receipt_record.get("owner_task_id") != ns.owner_task:
        raise SystemExit("taskspec_receipt_mismatch")
    validate_record_receipt(
        receipt_record,
        "taskspec_path",
        "taskspec_sha256",
        "taskspec_receipt_mismatch",
    )
    validate_record_receipt(
        receipt_record,
        "role_contract_path",
        "role_contract_sha256",
        "role_receipt_mismatch",
    )
    taskspec_path = str(receipt_record.get("taskspec_path") or "")
    taskspec_context = resolve_owner_task_context(taskspec_path, ns.cwd)
    if taskspec_context["taskspec_sha256"] != receipt_record.get("taskspec_sha256"):
        raise SystemExit("taskspec_receipt_mismatch")
    try:
        role_content = pathlib.Path(
            receipt_record["role_contract_path"]
        ).read_text(encoding="utf-8")
    except (KeyError, OSError, UnicodeError) as error:
        raise SystemExit("role_receipt_mismatch") from error
    worker_contract = {
        "path": receipt_record["role_contract_path"],
        "sha256": receipt_record["role_contract_sha256"],
        "version": receipt_record.get("role_contract_version"),
        "content": role_content,
    }
    return taskspec_path, taskspec_context, worker_contract


def load_routing_policy(path=None):
    policy_path = pathlib.Path(
        path
        or os.environ.get(
            "MYPEOPLE_ROUTING_POLICY_PATH",
            os.path.join(ROOT, "run", "routing-policy.json"),
        )
    )
    try:
        value = json.loads(policy_path.read_text(encoding="utf-8"))
    except FileNotFoundError as error:
        raise RoutingError("routing_policy_missing") from error
    except (OSError, UnicodeError, json.JSONDecodeError) as error:
        raise RoutingError("routing_policy_invalid") from error
    return validate_routing_policy(value)


def prepare_owner_routing(
    ns,
    taskspec_context,
    profile_id,
    receipt_record=None,
):
    if not ns.owner_task or ns.backend != "codex":
        return None, "", ""
    if receipt_record is not None:
        path = str(receipt_record.get("routing_path") or "")
        digest = str(receipt_record.get("routing_sha256") or "")
        if not path and not digest:
            return None, "", ""
        if not path or not digest:
            raise SystemExit("routing_receipt_mismatch")
        validate_record_receipt(
            receipt_record,
            "routing_path",
            "routing_sha256",
            "routing_receipt_mismatch",
        )
        try:
            raw = pathlib.Path(path).read_bytes()
            decision = json.loads(raw.decode("utf-8"))
            canonical = canonical_decision_bytes(decision)
        except (
            OSError,
            UnicodeError,
            json.JSONDecodeError,
            RoutingError,
        ) as error:
            raise SystemExit("routing_receipt_mismatch") from error
        if (
            canonical != raw
            or decision.get("taskId") != ns.owner_task
            or decision.get("providerProfile") != profile_id
            or decision.get("model") != receipt_record.get("model")
        ):
            raise SystemExit("routing_receipt_mismatch")
        return decision, path, digest

    policy = load_routing_policy()
    decision = route_task(
        taskspec_context.get("document"),
        policy,
        profile_id,
        requested_model=ns.model,
    )
    decisions_dir = os.environ.get(
        "MYPEOPLE_ROUTING_DECISIONS_DIR",
        os.path.join(ROOT, "run", "routing-decisions"),
    )
    path, digest = write_decision(decisions_dir, decision)
    return decision, path, digest


def ensure_routing_comment(task_id, decision, digest):
    marker = f"[routing:{digest[:12]}]"
    todo_base = (
        os.environ.get("MYPEOPLE_TODO_URL")
        or os.environ.get("TODO_URL")
        or f"http://127.0.0.1:{ENV.get('TODO_PORT', '9933')}"
    )
    board = http_json(
        "/todo/board",
        base=todo_base,
        token=ENV.get("QUEUE_SECRET", ""),
    )
    task = (board.get("tasks") or {}).get(task_id) or {}
    comments = task.get("comments") or []
    if any(
        marker in str(comment.get("body") or "")
        for comment in comments
        if isinstance(comment, dict)
    ):
        return False
    reasons = ",".join(decision.get("reasonCodes") or [])
    body = (
        f"{marker} class={decision['taskClass']} risk={decision['risk']} "
        f"tier={decision['tier']} model={decision['model']} "
        f"selection={decision['selection']} reasons={reasons} "
        f"aiUsage={decision['aiUsage']}"
    )
    http_json(
        "/todo/comment",
        "POST",
        {
            "task_id": task_id,
            "by": os.environ.get("AGENT_ID", "").strip() or "Boss",
            "body": body,
        },
        base=todo_base,
        token=ENV.get("QUEUE_SECRET", ""),
    )
    return True

def startup_message_for(ns, tab, initial_message=""):
    if str(initial_message or "").strip():
        return str(initial_message)
    if ns.master:
        return (
            "Read your Boss doctrine now. Internalize the queue quickstart, "
            "operate autonomously, and reply with a concise readiness summary "
            "containing plan, queue, mp, and verify."
        )
    if tab == "Nightwatch":
        doctrine = "AGENTS.md" if ns.backend == "codex" else "CLAUDE.md"
        return (
            f"Read {doctrine} and internalize the Nightwatch "
            "approve/edit/reject protocol. Reply with a concise nightwatch, "
            "CEO-equivalent, approve, WhatsApp, never-done readiness summary."
        )
    if ns.owner_task:
        return (
            "Read the TaskSpec at $MYPEOPLE_TASKSPEC_PATH. The MyPeople worker "
            "contract is already mounted; also follow the repository's own "
            f"instructions. Work only on owner task {ns.owner_task}, run the "
            "required verification, then report with mp complete and at least "
            "one --proof. Do not close the task yourself."
        )
    if ns.backend == "codex":
        return (
            "Initialize this temporary MyPeople worker session, read local "
            "project instructions when present, and reply with a concise "
            "readiness summary."
        )
    return ""

def spawn(
    ns,
    resume_session="",
    initial_message="",
    receipt_record=None,
):
    raw_boss = ns.boss
    if raw_boss is not None and not raw_boss.strip(): raise SystemExit("empty --boss is invalid; omit --boss for a top-level agent")
    if (ns.owner_task or ns.temporary) and raw_boss is None: raise SystemExit("--owner-task/--temporary require --boss")
    if ns.owner_task and ns.temporary: raise SystemExit("--owner-task and --temporary are mutually exclusive")
    if getattr(ns, "without_memory", False) and not ns.owner_task:
        raise SystemExit("--without-memory requires --owner-task")
    aid = full_agent_id(ns.agent_id); host, session, tab = parse_agent_id(aid)
    if host != ENV.get("HOST_ID"):
        model = ns.model if ns.model is not None else (
            ""
            if ns.master
            else None
            if ns.owner_task and ns.backend == "codex"
            else DEFAULT_ENG_MODEL
        )
        payload={"backend":ns.backend,"cwd":ns.cwd,"boss":raw_boss,"is_master":ns.master,"model":model,
                 "owner_task_id":ns.owner_task or "","temporary":ns.temporary,
                 "without_memory":bool(getattr(ns,"without_memory",False))}
        result=http_json("/task/submit","POST",{"type":"spawn","target_agent":aid,"payload":payload})
        print(result["task_id"]); return
    boss = full_agent_id(raw_boss) if raw_boss is not None else ""
    target=f"mc-{session}:{tab}"
    target_exists = window_exists(target)
    if ns.owner_task and target_exists:
        raise SystemExit(f"target_already_exists: {target}")
    taskspec_path = ""
    taskspec_context = {}
    worker_contract = None
    if ns.owner_task:
        try:
            (
                taskspec_path,
                taskspec_context,
                worker_contract,
            ) = resolve_owner_runtime(ns, receipt_record)
        except TaskSpecError as error:
            message = f"[taskspec] task {ns.owner_task} blocked: {error.code}. Fix the project/profile/context request and retry."
            if boss:
                notify_agent(boss, message)
            raise SystemExit(message) from error
        except OSError as error:
            message = f"[role] task {ns.owner_task} blocked: worker_contract_unavailable. Fix runtime role storage and retry."
            if boss:
                notify_agent(boss, message)
            raise SystemExit(message) from error
    fresh_owner_route = bool(
        ns.owner_task
        and ns.backend == "codex"
        and receipt_record is None
    )
    model = ns.model if ns.model is not None else (
        None if ns.master or fresh_owner_route else DEFAULT_ENG_MODEL
    )
    model, profile_id, provider_home = resolve_provider_runtime(
        aid,
        ns.backend,
        ns.master,
        tab,
        model,
        ns.model is not None or fresh_owner_route,
    )
    routing_decision = None
    routing_path = ""
    routing_sha256 = ""
    if ns.owner_task:
        try:
            (
                routing_decision,
                routing_path,
                routing_sha256,
            ) = prepare_owner_routing(
                ns,
                taskspec_context,
                profile_id,
                receipt_record=receipt_record,
            )
        except RoutingError as error:
            message = (
                f"[routing] task {ns.owner_task} blocked: {error.code}. "
                "Fix the routing policy or task limits and retry."
            )
            if boss:
                notify_agent(boss, message)
            raise SystemExit(error.code) from error
        if routing_decision is not None:
            model = routing_decision["model"]
    aid, host, session, tab, cwd, boss, args = _build_launch_args(
        aid,
        taskspec_context.get("cwd") if ns.owner_task else ns.cwd,
        boss,
        ns.master,
        model,
        ns.backend,
    )
    startup_message = startup_message_for(ns, tab, initial_message)
    if ns.backend == "codex" and ns.master:
        ensure_codex_doctrine(cwd)
    elif ns.backend == "codex" and tab == "Nightwatch":
        nightwatch_source = os.path.join(cwd, "CLAUDE.md")
        if os.path.exists(nightwatch_source):
            ensure_codex_doctrine(cwd, nightwatch_source)
    if ns.owner_task:
        args = mount_worker_contract(args, ns.backend, worker_contract)
    if resume_session:
        args = apply_resume_args(ns.backend, args, resume_session)
    if ns.model is not None and ns.master is False and tab != "Nightwatch":
        pass
    launch_env={"AGENT_ID":aid,"QUEUE_URL":ENV.get("QUEUE_URL","http://127.0.0.1:9900"),"TODO_URL":os.environ.get("MYPEOPLE_TODO_URL") or os.environ.get("TODO_URL") or f"http://127.0.0.1:{ENV.get('TODO_PORT','9933')}","QUEUE_SECRET":ENV["QUEUE_SECRET"],
                "HOST_ID":ENV["HOST_ID"],"INSTALL_DIR":ROOT,"BOSS_ID":boss or None,"OWNER_TASK_ID":ns.owner_task or "","LANG":"C.UTF-8","LC_ALL":"C.UTF-8"}
    if taskspec_path:
        launch_env["MYPEOPLE_TASKSPEC_PATH"] = taskspec_path
    if provider_home:
        launch_env["CODEX_HOME"] = provider_home
    if profile_id:
        launch_env["MYPEOPLE_PROVIDER_PROFILE"] = profile_id
    if os.environ.get("VERIFY_RESERVED_OWNER_ID"):
        launch_env["VERIFY_RESERVED_OWNER_ID"]=os.environ["VERIFY_RESERVED_OWNER_ID"]
    command=shell_export(launch_env)+"; exec "+shlex.join(args)
    previous=next((x for x in load_roster() if x.get("agent_id")==aid),{})
    fresh_session = not target_exists and not resume_session
    if target_exists or resume_session:
        session_id = str(resume_session or previous.get("session_id") or "")
        resume_state = previous.get("resume_state") or (
            "available" if session_id else "unavailable"
        )
    else:
        session_id = ""
        resume_state = "pending"
    session_identity = {
        "session_id": session_id,
        "session_backend": (
            ns.backend
            if fresh_session
            else previous.get("session_backend", ns.backend)
        ),
        "session_profile": (
            profile_id
            if fresh_session
            else previous.get("session_profile", profile_id)
        ),
        "session_cwd": (
            cwd
            if fresh_session
            else previous.get("session_cwd", cwd)
        ),
        "session_recorded_at": (
            0
            if fresh_session
            else previous.get("session_recorded_at", 0)
        ),
        "resume_state": resume_state,
        "recovery_attempts": previous.get("recovery_attempts", 0),
        "next_recovery_at": previous.get("next_recovery_at", 0),
        "recovery_state": previous.get("recovery_state", "healthy"),
        "last_recovery_error": previous.get("last_recovery_error", ""),
    }
    if resume_session:
        session_identity.update(
            session_id=resume_session,
            session_backend=ns.backend,
            session_profile=profile_id,
            session_cwd=cwd,
            resume_state="available",
            recovery_attempts=0,
            next_recovery_at=0,
            recovery_state="healthy",
            last_recovery_error="",
        )
    capture_enabled = ns.backend == "codex" and not target_exists and not resume_session
    capture_home = (
        provider_home
        or os.environ.get("CODEX_HOME")
        or os.path.expanduser("~/.codex")
    )
    capture_root = os.environ.get(
        "MYPEOPLE_SESSION_CAPTURE_DIR",
        os.path.join(ROOT, "run", "session-capture"),
    )
    capture_context = (
        capture_lock(
            capture_root,
            "codex",
            profile_id or "default",
            timeout=float(
                os.environ.get("MYPEOPLE_SESSION_CAPTURE_LOCK_SEC", "5")
            ),
        )
        if capture_enabled
        else contextlib.nullcontext()
    )
    created=False
    with capture_context:
        capture_before = (
            snapshot_codex_sessions(capture_home)
            if capture_enabled
            else set()
        )
        if not target_exists:
            if run_tmux(["has-session","-t",f"mc-{session}"],check=False).returncode:
                run_tmux(["new-session","-d","-s",f"mc-{session}","-n",tab,"-c",cwd,command])
                run_tmux(["set-option","-t",f"mc-{session}","-g","automatic-rename","off"],check=False)
            else:
                run_tmux(["new-window","-d","-t",f"mc-{session}","-n",tab,"-c",cwd,command])
            run_tmux(["set-option","-t",target,"-w","automatic-rename","off"])
            run_tmux(["set-option","-t",target,"-w","allow-rename","off"])
            run_tmux(["rename-window","-t",target,tab]); created=True
        if created and capture_enabled:
            try:
                if not wait_for_composer(target):
                    raise SessionError("session_process_not_ready")
                if not tmux_send_message(target, startup_message):
                    raise SessionError("session_process_not_ready")
                time.sleep(
                    float(
                        os.environ.get(
                            "MYPEOPLE_INITIAL_SUBMIT_RETRY_SEC",
                            "0.5",
                        )
                    )
                )
                if snapshot_codex_sessions(capture_home) == capture_before:
                    run_tmux(
                        ["send-keys", "-t", target, "Enter"],
                        check=False,
                    )
                discovered = discover_codex_session(
                    capture_home,
                    cwd,
                    capture_before,
                    timeout=float(
                        os.environ.get(
                            "MYPEOPLE_SESSION_CAPTURE_TIMEOUT_SEC",
                            "90",
                        )
                    ),
                )
                session_identity.update(
                    session_id=discovered["session_id"],
                    session_backend="codex",
                    session_profile=profile_id,
                    session_cwd=cwd,
                    session_recorded_at=time.time(),
                    resume_state="available",
                    last_recovery_error="",
                )
                if taskspec_context.get("memory_canary_attempt_id"):
                    session_identity["memory_usage_path"] = discovered["path"]
                    session_identity["memory_usage_before"] = (
                        memory_canary_usage_snapshot(
                            discovered["path"],
                            "codex",
                            discovered["session_id"],
                        )
                    )
            except SessionError as error:
                session_identity.update(
                    session_id="",
                    session_backend="codex",
                    session_profile=profile_id,
                    session_cwd=cwd,
                    resume_state="unavailable",
                    last_recovery_error=error.code,
                )
    lifecycle="owner" if ns.owner_task else "temporary" if ns.temporary else "unclassified"
    audit=["mp","spawn",aid,"--backend",ns.backend,"--cwd",cwd]
    if boss:audit += ["--boss",boss]
    if ns.master:audit += ["--master"]
    if model:audit += ["--model",model]
    if ns.owner_task:audit += ["--owner-task",ns.owner_task]
    if getattr(ns,"without_memory",False):audit += ["--without-memory"]
    if ns.temporary:audit += ["--temporary"]
    rec={**previous,"agent_id":aid,"host":host,"session":session,"tab":tab,"backend":ns.backend,"state":"alive",
         "boss_id":boss,"is_master":bool(ns.master),"cwd":cwd,"spawn_cmd":shlex.join(audit),"retired":False,
         "lifecycle":lifecycle,"owner_task_id":ns.owner_task or "","model":model or "","created":previous.get("created",time.time()),
         "stop_intent":"","retired_reason":"","retired_at":0,**session_identity}
    if taskspec_path:
        rec["taskspec_path"] = taskspec_path
        rec["taskspec_sha256"] = taskspec_context["taskspec_sha256"]
        if taskspec_context.get("memory_canary_attempt_id"):
            rec["memory_canary_attempt_id"] = taskspec_context[
                "memory_canary_attempt_id"
            ]
            rec["memory_usage_before"] = {}
    if worker_contract:
        rec["role_contract_path"] = worker_contract["path"]
        rec["role_contract_sha256"] = worker_contract["sha256"]
        rec["role_contract_version"] = worker_contract["version"]
    if routing_decision is not None:
        rec["routing_path"] = routing_path
        rec["routing_sha256"] = routing_sha256
        rec["routing_tier"] = routing_decision["tier"]
        rec["routing_selection"] = routing_decision["selection"]
        rec["routing_reason_codes"] = routing_decision["reasonCodes"]
        rec["routing_max_attempts"] = routing_decision["maxAttempts"]
        rec["routing_max_escalations"] = routing_decision["maxEscalations"]
    rec["provider_profile"] = profile_id
    if ns.master: rec["summary"]="autonomous plan approve queue mp verify fire-and-forget"
    if tab=="Nightwatch": rec["summary"]="nightwatch ceo-equivalent approve whatsapp never-done"
    if resume_session and created:
        if (
            not wait_for_composer(target)
            or not wait_for_stable_window(target)
        ):
            run_tmux(["kill-window","-t",target],check=False)
            raise RuntimeError("resume_process_failed")
    update_roster(rec); write_status(aid,"starting",rec.get("summary",""),boss_id=boss,backend=ns.backend)
    queue_register(rec); recorder(session,tab)
    if fresh_owner_route and routing_decision is not None:
        try:
            ensure_routing_comment(
                ns.owner_task,
                routing_decision,
                routing_sha256,
            )
        except Exception:
            print(
                "warning: routing comment deferred",
                file=sys.stderr,
            )
    if created and resume_session:
        pass
    elif created and capture_enabled:
        pass
    elif created and startup_message:
        wait_for_composer(target)
        tmux_send_message(target, startup_message)
    print(aid)

def notify_agent(agent_id, message):
    aid=full_agent_id(agent_id); host,_,_=parse_agent_id(aid)
    if host==ENV.get("HOST_ID"):
        write_status(aid,"working",activity_event="direct_send")
        if not tmux_send_message(tmux_target(aid),message):
            raise SystemExit(f"unable to notify {aid}")
    else:
        http_json("/task/submit","POST",{"type":"send","target_agent":aid,"payload":{"message":message}})

def send(ns):
    msg=" ".join(ns.message)
    if not msg.strip(): raise SystemExit("message must be non-empty")
    notify_agent(ns.agent_id,msg)

def http_multipart(path,fields,file_path):
    file_path=os.path.realpath(file_path)
    if not os.path.isfile(file_path):raise SystemExit(f"proof file not found: {file_path}")
    boundary="----mypeople"+uuid.uuid4().hex;chunks=[]
    for key,value in fields.items():chunks.append(f"--{boundary}\r\nContent-Disposition: form-data; name=\"{key}\"\r\n\r\n{value}\r\n".encode())
    name=os.path.basename(file_path);ctype=mimetypes.guess_type(name)[0] or "application/octet-stream"
    chunks.extend([f"--{boundary}\r\nContent-Disposition: form-data; name=\"file\"; filename=\"{name.replace(chr(34),'')}\"\r\nContent-Type: {ctype}\r\n\r\n".encode(),pathlib.Path(file_path).read_bytes(),b"\r\n",f"--{boundary}--\r\n".encode()])
    base=(os.environ.get("TODO_URL") or ENV.get("QUEUE_URL","http://127.0.0.1:9900")).rstrip("/")
    req=urllib.request.Request(base+path,data=b"".join(chunks),method="POST",headers={"X-Queue-Secret":ENV.get("QUEUE_SECRET",""),"Content-Type":"multipart/form-data; boundary="+boundary})
    try:
        with urllib.request.urlopen(req,timeout=60) as response:
            raw=response.read();return json.loads(raw) if raw else {}
    except Exception as e:raise SystemExit(f"evidence upload failed: {e}") from e

def complete(ns):
    actor=os.environ.get("AGENT_ID","").strip();task_id=os.environ.get("OWNER_TASK_ID","").strip();boss=os.environ.get("BOSS_ID","").strip();summary=" ".join(ns.summary).strip()
    proofs=[p.strip() for p in (getattr(ns,"proof",[]) or []) if p.strip()];files=[p.strip() for p in (getattr(ns,"proof_file",[]) or []) if p.strip()];urls=[p.strip() for p in (getattr(ns,"proof_url",[]) or []) if p.strip()]
    if not actor:raise SystemExit("AGENT_ID is required; run mp complete inside a managed worker")
    if not task_id:raise SystemExit("OWNER_TASK_ID is required; this worker does not own a task")
    if not boss:raise SystemExit("BOSS_ID is required; owner workers must report to a Boss")
    if not summary:raise SystemExit("summary must be non-empty")
    if not (proofs or files or urls):raise SystemExit("at least one --proof, --proof-file, or --proof-url is required")
    evidence=proofs+[f"file: {os.path.basename(x)}" for x in files]+[f"url: {x}" for x in urls]
    body="Worker handoff\n\nSummary: "+summary+"\n\nEvidence and verification:\n" + "\n".join(f"- {item}" for item in evidence)
    http_json("/todo/comment","POST",{"task_id":task_id,"by":actor,"body":body})
    for proof in proofs:http_json("/todo/proof","POST",{"task_id":task_id,"kind":"text","body":proof,"by":actor})
    for url in urls:http_json("/todo/proof","POST",{"task_id":task_id,"kind":"link","url":url,"by":actor})
    for file_path in files:http_multipart("/todo/proof",{"task_id":task_id,"by":actor},file_path)
    http_json("/todo/status","POST",{"task_id":task_id,"state":"review","verified":False,"by":actor})
    runtime_record=next((row for row in load_roster() if row.get("agent_id")==actor),{})
    attempt_id=str(runtime_record.get("memory_canary_attempt_id") or "")
    if attempt_id:
        try:
            usage_after=runtime_record.get("memory_usage_after") or {}
            if not usage_after and runtime_record.get("memory_usage_path"):
                usage_after=memory_canary_usage_snapshot(
                    runtime_record["memory_usage_path"],
                    runtime_record.get("backend"),
                    runtime_record.get("session_id"),
                )
            complete_memory_canary_attempt(
                os.path.realpath(os.path.join(ROOT,"run")),
                attempt_id=attempt_id,
                task_id=task_id,
                runtime_record=runtime_record,
                outcome="review",
                evidence_count=len(evidence),
                usage_before=runtime_record.get("memory_usage_before") or {},
                usage_after=usage_after,
                completed_at=time.time(),
            )
        except MemoryCanaryError as error:
            print(f"warning: memory canary completion telemetry failed: {error.code}",file=sys.stderr)
    write_status(actor,"idle",summary,activity_event="worker_handoff")
    notify_agent(boss,f"[worker handoff] {task_id} is ready for review from {actor}: {summary}")
    print(f"{task_id} -> review")

def peek(ns):
    aid=full_agent_id(ns.agent_id); host,_,_=parse_agent_id(aid)
    if host != ENV.get("HOST_ID"):
        print(http_json("/task/submit","POST",{"type":"peek","target_agent":aid,"payload":{}})); return
    p=run_tmux(["capture-pane","-p","-S","-200","-t",tmux_target(aid)],capture=True,check=False)
    status=load_json(status_path(aid),{}).get("status","ready").upper(); print(f"[{status}]\n{p.stdout}",end="")

def kill(ns):
    aid=full_agent_id(ns.agent_id); _,s,t=parse_agent_id(aid)
    rec=next((x for x in load_roster() if x.get("agent_id")==aid),None)
    if not rec:raise SystemExit("unknown agent")
    stopping={
        **rec,
        "retired":True,
        "state":"stopping",
        "stop_intent":"deliberate",
        "retired_reason":ns.reason or "operator-request",
        "retired_at":time.time(),
        "recovery_state":"stopped",
    }
    update_roster(stopping)
    run_tmux(["kill-window","-t",f"mc-{s}:{t}"],check=False); run_tmux(["kill-session","-t",f"rec-{t}"],check=False)
    final={**stopping,"state":"dead","recovery_state":"stopped"}
    update_roster(final)
    rows=load_roster()
    atomic_json(agents_path(),[r for r in rows if not r.get("retired") and window_exists(f"mc-{r.get('session')}:{r.get('tab')}")])
    try:http_json("/agents/unregister","POST",{"agent_id":aid})
    except Exception:pass

def namespace_from_record(rec):
    return argparse.Namespace(
        agent_id=rec["agent_id"],
        backend=rec.get("backend","claude"),
        cwd=rec.get("cwd",ROOT),
        boss=rec.get("boss_id") or None,
        master=bool(rec.get("is_master")),
        model=rec.get("model") or None,
        owner_task=rec.get("owner_task_id") if rec.get("lifecycle")=="owner" else None,
        temporary=rec.get("lifecycle")=="temporary",
        without_memory=False,
    )

def validate_record_receipt(rec,path_field,digest_field,error_code):
    path=rec.get(path_field);expected=rec.get(digest_field)
    if not path and not expected:return
    try:
        actual=hashlib.sha256(pathlib.Path(path).read_bytes()).hexdigest()
    except OSError as error:
        raise SystemExit(error_code) from error
    if not expected or actual!=expected:
        raise SystemExit(error_code)

def verify_owner_task_for_revive(rec,aid):
    task_id=rec.get("owner_task_id") if rec.get("lifecycle")=="owner" else ""
    if not task_id:return
    try:
        board=http_json("/todo/board",token=ENV.get("QUEUE_SECRET",""))
    except Exception as error:
        raise SystemExit(f"owner_task_verification_failed: {error}") from error
    task=(board.get("tasks") or {}).get(task_id)
    deleted=(board.get("deletedTasks") or {}).get(task_id)
    if deleted or not task:
        raise SystemExit("owner_task_closed: refusing revive")
    if task.get("state") in ("done","cancelled") or task.get("ownerNeedsReplacement"):
        raise SystemExit("owner_task_closed: refusing revive")
    if task.get("assignee") and task.get("assignee")!=aid:
        raise SystemExit("owner_task_reassigned: refusing revive")

def revive(ns):
    aid=full_agent_id(ns.agent_id); rec=next((x for x in load_roster() if x.get("agent_id")==aid),None)
    if not rec:raise SystemExit("unknown agent")
    if (rec.get("state")=="alive" or rec.get("retired") is False) and window_exists(tmux_target(aid)):
        raise SystemExit("agent_already_alive: refusing duplicate revive")
    verify_owner_task_for_revive(rec,aid)
    session_id=str(rec.get("session_id") or "")
    if not session_id or rec.get("resume_state")!="available":
        raise SystemExit("session_missing")
    backend=rec.get("backend","claude")
    if rec.get("session_backend")!=backend:
        raise SystemExit("session_identity_mismatch")
    real_cwd=os.path.realpath(rec.get("cwd",ROOT))
    if os.path.realpath(rec.get("session_cwd") or "")!=real_cwd:
        raise SystemExit("session_cwd_mismatch")
    _,_,tab=parse_agent_id(aid)
    _model,effective_profile,provider_home=resolve_provider_runtime(
        aid,backend,bool(rec.get("is_master")),tab,rec.get("model") or None,True
    )
    if backend=="claude":
        effective_profile=rec.get("provider_profile","")
    if rec.get("session_profile","")!=effective_profile:
        raise SystemExit("session_identity_mismatch")
    validate_record_receipt(rec,"taskspec_path","taskspec_sha256","taskspec_receipt_mismatch")
    validate_record_receipt(rec,"role_contract_path","role_contract_sha256","role_receipt_mismatch")
    try:
        validate_resume_evidence(
            backend,
            session_id,
            codex_home=provider_home or os.environ.get("CODEX_HOME") or os.path.expanduser("~/.codex"),
            claude_config_dir=os.environ.get("CLAUDE_CONFIG_DIR",""),
            expected_cwd=real_cwd,
        )
    except SessionError as error:
        raise SystemExit(error.code) from error
    snapshot=dict(rec)
    update_roster({**rec,"state":"recovering","recovery_state":"recovering"})
    try:
        spawn(
            namespace_from_record(rec),
            resume_session=session_id,
            receipt_record=rec,
        )
        if not window_exists(tmux_target(aid)):
            raise RuntimeError("resume_process_failed")
        current=next((x for x in load_roster() if x.get("agent_id")==aid),{})
        if current.get("session_id")!=session_id:
            raise RuntimeError("session_identity_mismatch")
    except SessionError as error:
        update_roster(snapshot)
        raise SystemExit(error.code) from error
    except BaseException:
        update_roster(snapshot)
        raise

def render_fresh_handoff(handoff):
    agent = handoff.get("agent") if isinstance(handoff, dict) else {}
    if not isinstance(agent, dict):
        agent = {}
    tail = str(handoff.get("terminalTail") or "")[-4000:]
    return (
        "This is a fresh provider session authorized by a provider-switch "
        "transaction; do not claim exact session resume. Read the mounted "
        "role doctrine and TaskSpec when present, preserve the same task and "
        "working directory, and continue from this sanitized handoff.\n\n"
        "Agent snapshot:\n"
        + json.dumps(agent, ensure_ascii=False, sort_keys=True)
        + "\n\nRecent terminal progress:\n"
        + tail
    )

def fresh_handoff(ns):
    transactions_root = os.environ.get(
        "PROVIDER_TRANSACTIONS_DIR",
        os.path.join(ROOT, "run", "provider-transactions"),
    )
    switch_lock = os.environ.get(
        "PROVIDER_SWITCH_LOCK",
        os.path.join(ROOT, "run", "provider-switch.lock"),
    )
    aid = full_agent_id(ns.agent_id)
    try:
        authorized = validate_fresh_handoff(
            transactions_root,
            switch_lock,
            ns.transaction,
            ns.handoff,
            aid,
        )
    except SessionError as error:
        raise SystemExit(error.code) from error
    record = authorized["record"]
    state = authorized.get("state") or {}
    runtime = namespace_from_record(record)
    runtime.backend = state.get("targetBackend") or runtime.backend
    runtime.model = state.get("targetModel") or runtime.model
    if runtime.backend not in {"codex", "claude"}:
        raise SystemExit("fresh_handoff_not_authorized")
    _, _, tab = parse_agent_id(aid)
    target_profile = str(state.get("targetProfile") or "")
    if runtime.backend == "codex":
        _model, effective_profile, _home = resolve_provider_runtime(
            aid,
            runtime.backend,
            bool(runtime.master),
            tab,
            runtime.model,
            runtime.model is not None,
        )
        if not target_profile or effective_profile != target_profile:
            raise SystemExit("fresh_handoff_not_authorized")
    elif target_profile:
        raise SystemExit("fresh_handoff_not_authorized")
    validate_record_receipt(
        record,
        "taskspec_path",
        "taskspec_sha256",
        "taskspec_receipt_mismatch",
    )
    validate_record_receipt(
        record,
        "role_contract_path",
        "role_contract_sha256",
        "role_receipt_mismatch",
    )
    spawn(
        runtime,
        resume_session="",
        initial_message=render_fresh_handoff(authorized["handoff"]),
        receipt_record=record,
    )

def switch_backend(ns):
    aid=full_agent_id(ns.agent_id); host,session,tab=parse_agent_id(aid)
    if host != ENV.get("HOST_ID"):raise SystemExit("remote backend switching is not supported")
    rec=next((x for x in load_roster() if x.get("agent_id")==aid),None)
    if not rec:raise SystemExit("unknown agent")
    if rec.get("backend")!=ns.backend:
        raise SystemExit("fresh_handoff_required")
    original=dict(rec)
    desired={**rec,"backend":ns.backend,"model":ns.model,"retired":False,
             "state":"switching","stop_intent":"","switched_at":time.time()}
    update_roster(desired)
    run_tmux(["kill-window","-t",f"mc-{session}:{tab}"],check=False)
    run_tmux(["kill-session","-t",f"rec-{tab}"],check=False)
    try:
        revive(argparse.Namespace(agent_id=aid))
    except BaseException:
        update_roster(original)
        raise

def reconcile(ns):
    selected=str(getattr(ns,"agent_id","") or "").strip()
    selected=full_agent_id(selected) if selected else ""
    current_time=time.time()
    attempted=[];blocked=[]
    for original in load_roster():
        rec=dict(original);aid=rec.get("agent_id","")
        if not aid or (selected and aid!=selected):continue
        if rec.get("retired") or rec.get("stop_intent")=="deliberate":continue
        if window_exists(tmux_target(aid)):
            if (
                rec.get("resume_state")=="available"
                and rec.get("session_id")
                and (
                rec.get("recovery_state")!="healthy"
                or int(rec.get("recovery_attempts") or 0)
                or float(rec.get("next_recovery_at") or 0)
                )
            ):
                update_roster({
                    **rec,
                    "state":"alive",
                    "recovery_state":"healthy",
                    "recovery_attempts":0,
                    "next_recovery_at":0,
                    "last_recovery_error":"",
                })
            continue
        attempts=int(rec.get("recovery_attempts") or 0)
        if float(rec.get("next_recovery_at") or 0)>current_time:continue
        if attempts>=RECOVERY_MAX:
            update_roster({
                **rec,
                "state":"dead",
                "recovery_state":"blocked",
                "last_recovery_error":"recovery_attempts_exhausted",
            })
            blocked.append(aid);continue
        session_id=str(rec.get("session_id") or "")
        if not session_id:
            status=load_json(status_path(aid),{})
            activity_state=status.get("status") or rec.get("state")
            started_at=float(status.get("timestamp") or rec.get("created") or current_time)
            if activity_state!="starting":
                update_roster({
                    **rec,
                    "state":"dead",
                    "recovery_state":"blocked",
                    "last_recovery_error":"session_missing",
                })
                blocked.append(aid);continue
            if current_time-started_at<STARTING_STALE:continue
            if attempts>=BOOTSTRAP_MAX:
                update_roster({
                    **rec,
                    "state":"dead",
                    "recovery_state":"blocked",
                    "last_recovery_error":"recovery_attempts_exhausted",
                })
                blocked.append(aid);continue
            next_attempt=attempts+1
            update_roster({
                **rec,
                "state":"starting",
                "recovery_state":"recovering",
                "recovery_attempts":next_attempt,
                "next_recovery_at":0,
                "last_recovery_error":"bootstrap_retry",
            })
            attempted.append(aid)
            try:
                spawn(
                    namespace_from_record(rec),
                    receipt_record=rec,
                )
            except BaseException:
                exhausted=next_attempt>=BOOTSTRAP_MAX
                update_roster({
                    **rec,
                    "state":"dead",
                    "recovery_state":"blocked" if exhausted else "cooldown",
                    "recovery_attempts":next_attempt,
                    "next_recovery_at":0 if exhausted else current_time+RECOVERY_COOLDOWN,
                    "last_recovery_error":"bootstrap_process_failed",
                })
                if exhausted:blocked.append(aid)
            continue
        next_attempt=attempts+1
        update_roster({
            **rec,
            "state":"recovering",
            "recovery_state":"recovering",
            "recovery_attempts":next_attempt,
            "next_recovery_at":0,
            "last_recovery_error":"",
        })
        attempted.append(aid)
        try:
            revive(argparse.Namespace(agent_id=aid))
        except BaseException:
            exhausted=next_attempt>=RECOVERY_MAX
            update_roster({
                **rec,
                "state":"dead",
                "recovery_state":"blocked" if exhausted else "cooldown",
                "recovery_attempts":next_attempt,
                "next_recovery_at":0 if exhausted else current_time+RECOVERY_COOLDOWN,
                "last_recovery_error":"resume_process_failed",
            })
            if exhausted:blocked.append(aid)
    print(json.dumps({"attempted":attempted,"blocked":blocked},sort_keys=True))

def status(_):
    try:
        for a in http_json("/agents"):print(f"{a['agent_id']} [{a['state']}] {a.get('status','ready')} {a.get('summary','')}")
    except Exception:
        for a in load_roster():print(f"{a['agent_id']} [{a.get('state','dead')}]")

def answer(ns):
    aid=full_agent_id(ns.agent_id); run_tmux(["send-keys","-t",tmux_target(aid),str(ns.choice),"Enter"])

def approve_publish(ns):
    try:
        record=approve_runtime(
            ns.task_id,ns.project,ns.commit,ns.branch,ns.ttl,
            mode=ns.mode,base_branch=ns.base,head_branch=ns.head,
            pr_title=ns.title,pr_body=ns.body,
        )
    except PublisherError as error:
        raise SystemExit(str(error)) from error
    print(record["approvalId"])

def run_publish(ns):
    try:
        record=publish_project(ns.approval_id,execute=not ns.check)
    except PublisherError as error:
        raise SystemExit(str(error)) from error
    print(json.dumps(record,sort_keys=True))

def publish_status(ns):
    try:
        record=get_approval(ns.approval_id)
    except PublisherError as error:
        raise SystemExit(str(error)) from error
    print(json.dumps(record,sort_keys=True))

def publish_pr_complete(ns):
    try:
        record=finalize_draft_pr(ns.approval_id,ns.number,ns.url)
    except PublisherError as error:
        raise SystemExit(str(error)) from error
    print(json.dumps(record,sort_keys=True))

def queue_retry(ns):
    result=http_json("/task/retry","POST",{"task_id":ns.task_id})
    print(json.dumps(result,sort_keys=True))

def queue_task_status(ns):
    result=http_json("/task/"+urllib.parse.quote(ns.task_id,safe=""))
    print(json.dumps(result,sort_keys=True))

def provider_pause_path():
    return os.environ.get(
        "PROVIDER_LAUNCH_PAUSE_PATH",
        os.path.join(ROOT,"run","provider-launch.paused"),
    )

def providers_pause(ns):
    print(json.dumps(pause_provider_launch(provider_pause_path(),ns.reason),sort_keys=True))

def providers_resume(_ns):
    resume_provider_launch(provider_pause_path())
    print(json.dumps({"paused":False},sort_keys=True))

def providers_status(_ns):
    print(json.dumps(provider_launch_status(provider_pause_path()),sort_keys=True))

def memory_canary_command(ns):
    runtime_dir=os.path.realpath(os.path.join(ROOT,"run"))
    try:
        if ns.memory_canary_action=="status":
            record=load_memory_canary_control(runtime_dir)
        elif ns.memory_canary_action=="enable":
            record=set_memory_canary_control(
                runtime_dir,
                enabled=True,
                project=ns.project,
            )
        elif ns.memory_canary_action=="disable":
            record=set_memory_canary_control(runtime_dir,enabled=False)
        else:
            raise MemoryCanaryError("canary_action_invalid")
    except MemoryCanaryError as error:
        raise SystemExit(error.code) from error
    print(json.dumps({
        "enabled":record["enabled"],
        "allowedProjects":record["allowedProjects"],
        "revision":record["revision"],
    },sort_keys=True))

def memory_comparison_command(ns):
    action=ns.memory_comparison_action
    payload={"op":action.replace("-","_"),"run_id":ns.run_id}
    try:
        if action=="init":
            document=json.loads(pathlib.Path(ns.cases_file).read_text(encoding="utf-8"))
            rows=document.get("cases") if isinstance(document,dict) else document
            payload={
                "op":"initialize","run_id":ns.run_id,
                "cases":[{"alias":row["alias"],"arm_order":row["arm_order"]} for row in rows if row.get("live",True)],
                "fixture_sha256":ns.fixture_sha,
                "offline_digest":ns.offline_digest,
            }
        elif action=="abort":
            payload["code"]=ns.code
        elif action=="start-arm":
            payload.update({
                "case_alias":ns.case_alias,"arm":ns.arm,
                "worker_id":ns.worker_id,"card_id":ns.card_id,
                "conversation_id":ns.conversation_id,
            })
        elif action=="submit-result":
            payload.update({
                "case_alias":ns.case_alias,"arm":ns.arm,
                "result":json.loads(pathlib.Path(ns.result_file).read_text(encoding="utf-8")),
            })
        elif action=="cleanup":
            payload["evidence"]={
                "worker_absent":ns.worker_absent,
                "card_absent":ns.card_absent,
                "conversation_retired":ns.conversation_retired,
                "temp_artifacts_absent":ns.temp_artifacts_absent,
            }
        elif action=="complete-pair":
            payload["case_alias"]=ns.case_alias
        result=http_json(
            "/todo/memory-comparison","POST",payload,
            base=os.environ.get("MYPEOPLE_TODO_URL") or os.environ.get("TODO_URL") or f"http://127.0.0.1:{ENV.get('TODO_PORT','9933')}",
            token=ENV.get("QUEUE_SECRET",""),
        )
    except (OSError,UnicodeError,json.JSONDecodeError,KeyError,TypeError,RuntimeError) as error:
        raise SystemExit(str(error)) from error
    print(json.dumps(result,ensure_ascii=False,sort_keys=True,separators=(",",":")))

def parser():
    p=argparse.ArgumentParser(prog="mp"); sub=p.add_subparsers(dest="verb",required=True)
    q=sub.add_parser("spawn");q.add_argument("agent_id");q.add_argument("--backend",default="claude",choices=["claude","codex"]);q.add_argument("--cwd");q.add_argument("--boss");q.add_argument("--master",action="store_true");q.add_argument("--model");g=q.add_mutually_exclusive_group();g.add_argument("--owner-task");g.add_argument("--temporary",action="store_true");q.add_argument("--without-memory",action="store_true");q.set_defaults(fn=spawn)
    q=sub.add_parser("send");q.add_argument("agent_id");q.add_argument("message",nargs="+");q.set_defaults(fn=send)
    q=sub.add_parser("complete");q.add_argument("summary",nargs="+");q.add_argument("--proof",action="append",default=[]);q.add_argument("--proof-file",action="append",default=[]);q.add_argument("--proof-url",action="append",default=[]);q.set_defaults(fn=complete)
    q=sub.add_parser("peek");q.add_argument("agent_id");q.set_defaults(fn=peek)
    q=sub.add_parser("kill");q.add_argument("agent_id");q.add_argument("--reason");q.set_defaults(fn=kill)
    q=sub.add_parser("revive");q.add_argument("agent_id");q.set_defaults(fn=revive)
    q=sub.add_parser("switch");q.add_argument("agent_id");q.add_argument("--backend",required=True,choices=["claude","codex"]);q.add_argument("--model",required=True);q.set_defaults(fn=switch_backend)
    q=sub.add_parser("fresh-handoff");q.add_argument("agent_id");q.add_argument("--transaction",required=True);q.add_argument("--handoff",required=True);q.set_defaults(fn=fresh_handoff)
    q=sub.add_parser("reconcile");q.add_argument("--agent",dest="agent_id",default="");q.set_defaults(fn=reconcile)
    q=sub.add_parser("answer");q.add_argument("agent_id");q.add_argument("choice",type=int);q.set_defaults(fn=answer)
    q=sub.add_parser("status");q.set_defaults(fn=status)
    q=sub.add_parser("approve-publish");q.add_argument("task_id");q.add_argument("--project",required=True);q.add_argument("--commit",required=True);q.add_argument("--branch",default="main");q.add_argument("--ttl",type=int,default=900);q.add_argument("--mode",choices=["direct_main","draft_pr"],default="direct_main");q.add_argument("--base");q.add_argument("--head");q.add_argument("--title");q.add_argument("--body");q.set_defaults(fn=approve_publish)
    q=sub.add_parser("publish");q.add_argument("approval_id");q.add_argument("--check",action="store_true");q.set_defaults(fn=run_publish)
    q=sub.add_parser("publish-status");q.add_argument("approval_id");q.set_defaults(fn=publish_status)
    q=sub.add_parser("publish-pr-complete");q.add_argument("approval_id");q.add_argument("--number",type=int,required=True);q.add_argument("--url",required=True);q.set_defaults(fn=publish_pr_complete)
    q=sub.add_parser("queue-retry");q.add_argument("task_id");q.set_defaults(fn=queue_retry)
    q=sub.add_parser("queue-status");q.add_argument("task_id");q.set_defaults(fn=queue_task_status)
    q=sub.add_parser("providers-pause");q.add_argument("--reason",default="operator requested");q.set_defaults(fn=providers_pause)
    q=sub.add_parser("providers-resume");q.set_defaults(fn=providers_resume)
    q=sub.add_parser("providers-status");q.set_defaults(fn=providers_status)
    canary=sub.add_parser("memory-canary")
    canary_sub=canary.add_subparsers(dest="memory_canary_action",required=True)
    canary_sub.add_parser("status")
    enable=canary_sub.add_parser("enable");enable.add_argument("--project",required=True)
    canary_sub.add_parser("disable")
    canary.set_defaults(fn=memory_canary_command)
    comparison=sub.add_parser("memory-comparison")
    comparison_sub=comparison.add_subparsers(dest="memory_comparison_action",required=True)
    q=comparison_sub.add_parser("init");q.add_argument("run_id");q.add_argument("--cases-file",required=True);q.add_argument("--fixture-sha",required=True);q.add_argument("--offline-digest",required=True)
    q=comparison_sub.add_parser("status");q.add_argument("run_id")
    q=comparison_sub.add_parser("abort");q.add_argument("run_id");q.add_argument("--code",default="operator_abort")
    q=comparison_sub.add_parser("start-arm");q.add_argument("run_id");q.add_argument("--case-alias",required=True);q.add_argument("--arm",required=True,choices=["baseline","memory"]);q.add_argument("--worker-id",required=True);q.add_argument("--card-id",required=True);q.add_argument("--conversation-id",required=True)
    q=comparison_sub.add_parser("submit-result");q.add_argument("run_id");q.add_argument("--case-alias",required=True);q.add_argument("--arm",required=True,choices=["baseline","memory"]);q.add_argument("--result-file",required=True)
    q=comparison_sub.add_parser("cleanup");q.add_argument("run_id");q.add_argument("--worker-absent",action="store_true",required=True);q.add_argument("--card-absent",action="store_true",required=True);q.add_argument("--conversation-retired",action="store_true",required=True);q.add_argument("--temp-artifacts-absent",action="store_true",required=True)
    q=comparison_sub.add_parser("complete-pair");q.add_argument("run_id");q.add_argument("--case-alias",required=True)
    q=comparison_sub.add_parser("complete-run");q.add_argument("run_id")
    q=comparison_sub.add_parser("summary");q.add_argument("run_id")
    comparison.set_defaults(fn=memory_comparison_command)
    return p

def main(argv=None):
    ns=parser().parse_args(argv); return ns.fn(ns)
if __name__=="__main__": main()
