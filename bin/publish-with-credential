#!/usr/bin/env python3
"""Consume one transient credential payload and run the approved publisher."""
from __future__ import annotations

import json
import os
import pathlib
import sys

from project_publisher import PublisherError, publish


def main() -> int:
    if len(sys.argv) != 2:
        raise SystemExit("usage: publish-with-credential <approval-id>")
    try:
        payload = json.load(sys.stdin)
    except (json.JSONDecodeError, OSError) as error:
        raise SystemExit("invalid credential payload") from error
    username = payload.get("username") if isinstance(payload, dict) else None
    secret = payload.get("password") if isinstance(payload, dict) else None
    if not isinstance(username, str) or not isinstance(secret, str):
        raise SystemExit("credential payload requires username and password")
    if (
        not username
        or not secret
        or len(username) > 512
        or len(secret) > 4096
        or any(character in username + secret for character in "\r\n\0")
    ):
        raise SystemExit("credential payload is invalid")
    askpass = pathlib.Path(__file__).with_name("mypeople-git-askpass")
    os.environ.update(
        MYPEOPLE_GIT_USERNAME=username,
        MYPEOPLE_GIT_PASSWORD=secret,
        GIT_ASKPASS=str(askpass),
        GIT_TERMINAL_PROMPT="0",
    )
    try:
        record = publish(sys.argv[1], execute=True)
        print(json.dumps(record, sort_keys=True))
    except PublisherError as error:
        raise SystemExit(str(error)) from error
    finally:
        for key in (
            "MYPEOPLE_GIT_USERNAME",
            "MYPEOPLE_GIT_PASSWORD",
            "GIT_ASKPASS",
            "GIT_TERMINAL_PROMPT",
        ):
            os.environ.pop(key, None)
        payload = None
        username = None
        secret = None
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
